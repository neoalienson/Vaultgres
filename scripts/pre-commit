#!/bin/bash

echo "Running pre-commit checks..."

echo "Checking for sensitive information..."
if command -v gitleaks >/dev/null 2>&1; then
    gitleaks protect --staged --verbose 2>&1 | grep -v "^INFO" || true
    if [ ${PIPESTATUS[0]} -ne 0 ]; then
        echo "❌ Gitleaks found potential secrets. Review and remove them."
        exit 1
    fi
else
    if git diff --cached --name-only | xargs grep -nHE '(password|secret|api[_-]?key|token|credential|private[_-]?key)\s*=\s*["'"'"'][^"'"'"']+["'"'"']' 2>/dev/null; then
        echo "❌ Found potential credentials. Install gitleaks for better detection: brew install gitleaks"
        exit 1
    fi
fi
echo "✓ No secrets found"

echo "Checking code formatting..."
cargo fmt --all -- --check > /dev/null 2>&1
if [ $? -ne 0 ]; then
    echo "❌ Code formatting check failed. Run 'cargo fmt --all' to fix."
    exit 1
fi
echo "✓ Formatting OK"

echo "Running clippy..."
cargo clippy --all-targets --all-features -- -W clippy::all 2>&1 | grep -E "^(error|warning:.*error)" 
if [ ${PIPESTATUS[0]} -ne 0 ]; then
    echo "❌ Clippy found errors. Run 'cargo clippy --fix' to fix."
    exit 1
fi
echo "✓ Clippy OK"

echo "Running tests..."
cargo test 2>&1 | tail -5
if [ ${PIPESTATUS[0]} -ne 0 ]; then
    echo "❌ Tests failed."
    exit 1
fi
echo "✓ Tests OK"
